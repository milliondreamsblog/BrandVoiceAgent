# Copy to .env.local and fill these in. .env.local is gitignored.

# Required — the app throws at import without a Neon Postgres URL.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
# Optional — preferred for DDL (db:push / gen:pairs). Falls back to DATABASE_URL.
# DATABASE_URL_UNPOOLED=postgres://user:pass@host-unpooled/db?sslmode=require

# Required for any model call (generate / critique / rehook / ideation).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional model overrides (defaults shown). Prod stays on Opus; drop to a cheap
# model for tests/offline without touching code.
# TONE_MODEL=claude-opus-4-8          # founder-facing voice output (generate / critique / rehook)
# IDEATION_MODEL=claude-haiku-4-5     # idea extraction (not voice work)
# GENPAIRS_MODEL=claude-haiku-4-5     # /train deck generation (calibration data)
